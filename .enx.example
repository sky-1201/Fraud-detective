# ==========================================
#  AI 反欺诈风控中枢 - 环境变量配置模板
# 使用说明:
# 1. 复制本文件并重命名为 `.env`
# 2. 填入你实际的数据库密码和 API 密钥
# 3. 绝对不要将 `.env` 文件提交到代码仓库！
# ==========================================

# ------------------------------------------
#  LLM 大模型配置 (LangChain 核心驱动)
# ------------------------------------------
# 你的 OpenAI 格式 API Key (如果是阿里/百度/智谱等，填入对应的 API Key)
OPENAI_API_KEY=sk-your-api-key-here
# 代理或第三方大模型服务地址 (必须带 /v1)
OPENAI_API_BASE=https://api.openai.com/v1
# AI 专案组使用的模型名称 (默认使用 qwen，可改为 gpt-4o, claude-3-5-sonnet 等)
LLM_MODEL_ANALYST=qwen-max
LLM_MODEL_ROUTER=qwen-turbo

# ------------------------------------------
#  MySQL 关系型数据库配置 (雷达扫描底座)
# ------------------------------------------
# 如果使用 Docker 部署且在同一网络，HOST 可写为容器名 (如 fraud_mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# 【必填】MySQL 密码，必须与 docker-compose.yml 中保持一致
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=fraud_db

# ------------------------------------------
#  Neo4j 图数据库配置 (深层网络穿透底座)
# ------------------------------------------
# 注意：在 Windows + Eventlet 运行 Celery 时，务必写 127.0.0.1，不要写 localhost
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
# 【必填】Neo4j 密码，必须与 docker-compose.yml 中保持一致
NEO4J_PASSWORD=your_neo4j_password_here

# ------------------------------------------
#  Redis 配置 (Celery 异步任务队列消息代理)
# ------------------------------------------
# 注意：在 Windows 下同样建议写 127.0.0.1
REDIS_URL=redis://127.0.0.1:6379/0

# ------------------------------------------
#  基础 API 与前端联动配置
# ------------------------------------------
# 后端 API 挂载的路由前缀
API_V1_STR=/api
# 前端访问后端的地址 (本地调试为 127.0.0.1，云端部署时改为服务器 IP 或域名)
API_BASE_URL=http://127.0.0.1:8000/api